  },
  {
    number: "05",
    title: "Synoit",
    eyebrow: "Technology company platform",
    url: "https://synoit.com",
    role: "Frontend Developer",
    stack: ["Angular", "TypeScript", "HTML5", "SCSS", "Firebase"],
    summary: "A performance-focused company website with responsive landing pages, service journeys and reusable interface components.",
    impact: "Designed, developed, optimized and deployed the complete web experience on Firebase Hosting.",
    tone: "plum",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Raiyan Rashid Prodhan",
  jobTitle: "Senior Full Stack Developer",
  url: new URL(Astro.url.pathname, Astro.site).href,
  image: new URL("/images/raiyan-rashid-prodhan.jpg", Astro.site).href,
  email: "mailto:rrprodhan1998@gmail.com",
  telephone: "+8801575579841",
  address: {
    "@type": "PostalAddress",
    streetAddress: "130/10/1C, Madartek-02",
    addressLocality: "Dhaka",
    postalCode: "1214",
    addressCountry: "BD",
  },
  sameAs: ["https://github.com/rrprodhan", "https://www.linkedin.com/in/rrprodhan/"],
  alumniOf: [
    { "@type": "CollegeOrUniversity", name: "East West University" },
    { "@type": "CollegeOrUniversity", name: "IBA, University of Dhaka" },
  ],
  knowsAbout: ["Angular", "TypeScript", "Node.js", "NestJS", "Django", "PostgreSQL", "SaaS architecture", "Web performance"],

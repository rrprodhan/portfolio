      "Developed enterprise SaaS products with Angular, TypeScript, NestJS and PostgreSQL.",
      "Built responsive dashboards and reusable interface systems backed by REST APIs.",
      "Helped migrate a Restify backend to NestJS for stronger scalability and maintainability.",
    ],
  },
];

const projects = [
  {
    number: "01",
    title: "Agricultural Decision Support Systems",
    eyebrow: "Multi-country climate technology",
    url: "https://bamis.rimes.int",
    role: "Senior Full Stack Developer",
    stack: ["Angular", "Angular Material", "Django", "PostgreSQL", "Redis"],
    summary: "Reusable advisory systems serving farmers and decision-makers across eight countries, with multilingual weather, crop and pest intelligence.",
    impact: "Reduced advisory generation from 60 seconds to under 400ms through Redis and asynchronous processing.",
    tone: "sage",
  },
  {
    number: "02",
    title: "TekumoPRO",
    eyebrow: "USA field-service SaaS",
    url: "https://www.tekumo.com",
    role: "Full Stack Developer",
    stack: ["Angular", "Angular Material", "NestJS", "PostgreSQL"],
    summary: "Production modules that streamline orders, dispatch and field operations with responsive, real-time operational dashboards.",
    impact: "Optimized APIs and database queries, and automated invoices and operational email workflows.",
    tone: "blue",
  },
  {
    number: "03",
    title: "Flood Forecasting & Warning Centre",
    eyebrow: "Bangladesh disaster response",
    url: "https://ffwc.gov.bd",
    role: "Frontend Developer",
    stack: ["Angular", "Leaflet", "Django", "PostgreSQL"],
    summary: "A flash-flood forecasting module and interactive geospatial dashboards supporting national disaster preparedness and response.",
    impact: "Optimized large-map rendering for faster, more usable flood-risk visualization.",
    tone: "sand",
  },
  {
    number: "04",
    title: "Luminous Engineering",
    eyebrow: "Singapore engineering company",
    url: "https://luminousengineering.com.sg",
    role: "Frontend Developer",
    stack: ["HTML5", "SCSS", "JavaScript", "GA4", "Hostinger"],

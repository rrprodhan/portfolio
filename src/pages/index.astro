const description = "Senior Full Stack Developer in Dhaka with 5+ years building scalable Angular, Node.js, NestJS, Django and PostgreSQL products across Asia-Pacific and Africa.";

const skills = [
  { group: "Frontend", items: ["Angular", "TypeScript", "JavaScript ES6+", "RxJS", "Angular Material", "HTML5", "CSS3 / SCSS", "Bootstrap"] },
  { group: "Backend", items: ["Node.js", "NestJS", "Django", "Express.js", "REST APIs", "Redis"] },
  { group: "Data & architecture", items: ["PostgreSQL", "SQL", "Knex.js", "Schema design", "Query optimization", "Authentication", "State management"] },
  { group: "Tools & delivery", items: ["Git & GitHub", "Docker", "Postman", "Firebase Hosting", "Hostinger", "GA4"] },
];

const experience = [
  {
    period: "Jun 2023 — Present",
    company: "RIMES",
    expansion: "Regional Integrated Multi-Hazard Early Warning System",
    role: "Senior Full Stack Developer",
    points: [
      "Lead Angular development for climate and Agritech systems delivered across eight countries.",
      "Upgraded applications from Angular 14 to 17, reducing build times by 30–60%.",
      "Improved UI performance with lazy loading, caching and pragmatic state management.",
      "Integrate weather REST APIs and lead code reviews with distributed international teams.",
    ],
  },
  {
    period: "Jun 2020 — May 2023",
    company: "Intelletive Technologies Bangladesh",
    expansion: "",
